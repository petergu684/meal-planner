# Meal Planner Configuration
# Copy this to .env and fill in your values

# Data directory — where the database, uploads, and backups are stored
# Default: ./data (relative to server.py)
MEAL_PLANNER_DATA=./data

# Server port
MEAL_PLANNER_PORT=8091

# (Optional) WeChat reminder configuration
# WECHAT_TARGET=your_wechat_id@im.wechat
# WECHAT_ACCOUNT_FILE=/path/to/openclaw-weixin/accounts/xxx.json
